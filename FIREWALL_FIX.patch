ADD NEW: Firewall cracking logic

  function crackFirewall(targetIp){
    const ip=targetIp||GS.host;
    const node=NET[ip];
    if(!node){tprint('Not connected.','terr');return;}
    if(node.firewallLayers===0){tprint('No firewall active.','tok');return;}
    
    const cracked=node.ports ? Object.values(node.ports).filter(p=>p.cracked).length : 0;
    const total=node.ports ? Object.keys(node.ports).length : 0;
    const needed=Math.max(1,Math.ceil(total/2));
    
    if(cracked<needed){
      tprint(`Crack ${needed} ports to break through firewall. Currently: ${cracked}/${total}.`,'twrn');
      return;
    }
    
    // Once enough ports cracked, firewall is breached
    node.firewallLayers=0;
    tprint('✓ Firewall breached! Full access granted.','thack');
    updateRemote(ip);
  }

KEY INSIGHT:
- Connection is just setting GS.host
- Firewall blocks FILE ACCESS, not connection
- User sees "connected but can't access files" if firewall active
- Cracking ports eventually disables firewall
- Once firewall disabled, full file system access
