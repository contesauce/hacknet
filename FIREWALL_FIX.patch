WITH THIS:
  connect:{run:(args)=>{
    if(!args[0]){tprint('Usage: connect [ip]','twrn');return;}
    const ip=args[0]; const node=NET[ip];
    if(!node){tprint('Unknown host: '+ip,'terr');return;}
    if(!GS.discovered.includes(ip)){tprint('Unknown node. Run scan first.','terr');return;}
    
    // Check if reachable via hops
    let reachable=false;
    if(ip==='localhost') reachable=true;
    else if(GS.hops.length>0) reachable=GS.hops.includes(ip) || NET[GS.host]?.connections?.includes(ip);
    else reachable=NET['localhost']?.connections?.includes(ip);
    
    if(!reachable){tprint('Host not reachable. Check hops or connections.','terr');return;}
    
    GS.host=ip;
    tprint('Connected to '+ip+' ('+node.name+')','tok');
    
    // IMPORTANT: Show firewall status but DON'T block connection
    if(node.firewallLayers>0){
      tprint('⚠ FIREWALL ACTIVE: '+node.firewallLayers+' layer(s). Crack ports to proceed.','terr');
    }
    
    updateRemote(ip);
    renderFiles();
    updateHUD();
  }},

